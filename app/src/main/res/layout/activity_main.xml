<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1C1C1E"
    android:padding="12dp">

    <!-- DISPLAY -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="bottom|end"
        android:paddingBottom="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/tvExpressao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#8E8E93"
            android:textSize="24sp"
            android:gravity="end"/>

        <TextView
            android:id="@+id/tvDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="72sp"
            android:gravity="end"
            android:maxLines="1"
            android:ellipsize="start"/>

    </LinearLayout>

    <!-- LINHA 1: AC | +/- | % | ÷ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <Button
            android:id="@+id/btnLimpar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="AC"
            android:textColor="#1C1C1E"
            android:textSize="20sp"
            android:backgroundTint="#A5A5A5"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnInverter"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="+/-"
            android:textColor="#1C1C1E"
            android:textSize="20sp"
            android:backgroundTint="#A5A5A5"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnPorcento"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="%"
            android:textColor="#1C1C1E"
            android:textSize="20sp"
            android:backgroundTint="#A5A5A5"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnDividir"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="÷"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:backgroundTint="#FF9500"
            android:stateListAnimator="@null"/>

    </LinearLayout>

    <!-- LINHA 2: 7 | 8 | 9 | × -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <Button
            android:id="@+id/btn7"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="7"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:backgroundTint="#333333"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btn8"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="8"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:backgroundTint="#333333"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btn9"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="9"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:backgroundTint="#333333"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnMultiplicar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="×"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:backgroundTint="#FF9500"
            android:stateListAnimator="@null"/>

    </LinearLayout>

    <!-- LINHA 3: 4 | 5 | 6 | − -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <Button
            android:id="@+id/btn4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="4"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:backgroundTint="#333333"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btn5"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="5"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:backgroundTint="#333333"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btn6"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="6"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:backgroundTint="#333333"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnSubtrair"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="−"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:backgroundTint="#FF9500"
            android:stateListAnimator="@null"/>

    </LinearLayout>

    <!-- LINHA 4: 1 | 2 | 3 | + -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <Button
            android:id="@+id/btn1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="1"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:backgroundTint="#333333"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btn2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="2"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:backgroundTint="#333333"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btn3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="3"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:backgroundTint="#333333"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnSomar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:backgroundTint="#FF9500"
            android:stateListAnimator="@null"/>

    </LinearLayout>

    <!-- LINHA 5: 0 (largo) | . | = -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btn0"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:layout_marginEnd="10dp"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:gravity="center_vertical|start"
            android:paddingStart="28dp"
            android:backgroundTint="#333333"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnPonto"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="."
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:backgroundTint="#333333"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnIgual"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="="
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:backgroundTint="#FF9500"
            android:stateListAnimator="@null"/>

    </LinearLayout>

</LinearLayout>